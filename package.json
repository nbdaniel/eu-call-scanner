{
  "name": "eu-call-scanner",
  "version": "1.0.0",
  "description": "EU funding call scanner agent for Asociația Mereu pentru Europa (AMPE). Monitors EU funding portals, parses calls with Claude API, scores relevance, and delivers weekly briefings.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "eu-scanner": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "scan": "node src/index.js scan",
    "briefing": "node src/index.js briefing",
    "serve": "node src/index.js serve",
    "test": "node --test src/**/*.test.js",
    "migrate": "node src/db/migrate.js"
  },
  "keywords": ["eu-funding", "erasmus", "interreg", "structural-funds", "scanner"],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.9.16",
    "pino": "^9.6.0",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
