ANTHROPIC_API_KEY=

# Models (haiku = cheap/fast for bulk, sonnet = quality for briefing)
PARSE_MODEL=claude-haiku-4-5-20251001
SCORE_MODEL=claude-haiku-4-5-20251001
BRIEF_MODEL=claude-sonnet-4-6

# Cron schedule for `npm run schedule` (default: every Monday at 08:00)
SCAN_CRON=0 8 * * 1

# Optional: print stack traces on fatal errors
DEBUG=
