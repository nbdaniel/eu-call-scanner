# === Required ===
ANTHROPIC_API_KEY=sk-ant-...

# === Claude Model (optional) ===
# CLAUDE_MODEL=claude-sonnet-4-20250514

# === Email / SMTP (optional — needed for --send) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=scanner@ampe.ro
# EMAIL_TO=director@ampe.ro,projects@ampe.ro

# === Database ===
# DB_PATH=./data/scanner.db

# === Scheduling (cron expressions) ===
# SCAN_CRON=0 6 * * 1        # Every Monday at 06:00
# BRIEFING_CRON=0 8 * * 1    # Every Monday at 08:00

# === Scoring ===
# MIN_RELEVANCE_SCORE=0.4    # Minimum score (0-1) to include in briefings

# === Performance ===
# MAX_CONCURRENT_SCRAPES=3

# === Logging ===
# LOG_LEVEL=info              # trace, debug, info, warn, error, fatal
